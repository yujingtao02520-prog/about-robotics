<mujoco model="pendulum_demo">
  <compiler angle="degree"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.14 0.16 0.18" rgb2="0.22 0.25 0.27" width="300" height="300"/>
    <material name="grid" texture="grid" texrepeat="4 4" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light name="key" pos="0 -3 4" dir="0 1 -1"/>
    <camera name="demo" pos="0 -2.5 1.1" xyaxes="1 0 0 0 0 1"/>
    <geom name="floor" type="plane" size="1.5 1.5 0.02" material="grid"/>

    <body name="pendulum" pos="0 0 1.05">
      <joint name="hinge" type="hinge" axis="0 1 0" damping="0.05"/>
      <geom name="pivot" type="sphere" size="0.04" rgba="0.9 0.25 0.2 1"/>
      <geom name="arm" type="capsule" fromto="0 0 0 0 0 -0.75" size="0.025" mass="0.3" rgba="0.2 0.45 0.95 1"/>
      <body name="bob" pos="0 0 -0.82">
        <geom name="bob_geom" type="sphere" size="0.09" mass="0.7" rgba="0.95 0.74 0.18 1"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="hinge_motor" joint="hinge" gear="0.12"/>
  </actuator>
</mujoco>
